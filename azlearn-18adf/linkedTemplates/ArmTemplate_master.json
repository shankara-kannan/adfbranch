{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "azlearn-18adf"
		},
		"database_connection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'database_connection'"
		},
		"src_datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'src_datalake'"
		},
		"database_connection_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver1806.database.windows.net"
		},
		"database_connection_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azuresql"
		},
		"database_connection_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "shankar"
		},
		"src_datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://shan18cc.dfs.core.windows.net/"
		},
		"trigger1_properties_Schedule Pipeline_parameters_source": {
			"type": "string",
			"defaultValue": "Shankar"
		},
		"trigger1_properties_Schedule Pipeline_parameters_table": {
			"type": "string",
			"defaultValue": "Orders"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "azlearn-18adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"database_connection_password": {
						"value": "[parameters('database_connection_password')]"
					},
					"src_datalake_accountKey": {
						"value": "[parameters('src_datalake_accountKey')]"
					},
					"database_connection_properties_typeProperties_server": {
						"value": "[parameters('database_connection_properties_typeProperties_server')]"
					},
					"database_connection_properties_typeProperties_database": {
						"value": "[parameters('database_connection_properties_typeProperties_database')]"
					},
					"database_connection_properties_typeProperties_userName": {
						"value": "[parameters('database_connection_properties_typeProperties_userName')]"
					},
					"src_datalake_properties_typeProperties_url": {
						"value": "[parameters('src_datalake_properties_typeProperties_url')]"
					},
					"trigger1_properties_Schedule Pipeline_parameters_source": {
						"value": "[parameters('trigger1_properties_Schedule Pipeline_parameters_source')]"
					},
					"trigger1_properties_Schedule Pipeline_parameters_table": {
						"value": "[parameters('trigger1_properties_Schedule Pipeline_parameters_table')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}